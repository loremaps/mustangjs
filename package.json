  "files": [
    "dist/src/",
    "src/validation/schematron/"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.11",
    "big.js": "^6.2.2",
    "saxon-js": "^2.7.0",
    "xpath": "^0.0.34"
  },
  "devDependencies": {
    "@types/big.js": "^6.2.2",
    "@types/node": "^25.5.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "Apache-2.0"
}
