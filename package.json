{
  "name": "@aifind/mustangjs",
  "version": "0.3.0",
  "description": "TypeScript port of mustangproject - ZUGFeRD, Factur-X, XRechnung e-invoicing library",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src/",
    "src/validation/schematron/",
    "NOTICE"
  ],
  "keywords": [
    "zugferd",
    "factur-x",
    "xrechnung",
    "en16931",
    "e-invoice",
    "einvoicing",
    "cii",
    "ubl",
    "mustangproject"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loremaps/mustangjs.git"
  },
  "homepage": "https://github.com/loremaps/mustangjs#readme",
  "bugs": {
    "url": "https://github.com/loremaps/mustangjs/issues"
  },
  "author": "Panagiotis Kapros <kapros@gmail.com>",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build",
    "prepublishOnly": "npm test"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.10",
    "big.js": "^6.2.2",
    "saxon-js": "^2.7.0",
    "xpath": "^0.0.34"
  },
  "devDependencies": {
    "@types/big.js": "^6.2.2",
    "@types/node": "^25.5.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0"
}
